{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "image": "latest" }
    },
    "simulator": {
      "distribution": "internal",
      "ios": { "simulator": true, "image": "latest" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "image": "latest" }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "image": "latest" }
    },
    "production-pro": {
      "extends": "production",
      "env": { "APP_VARIANT": "pro" }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "6783919397" }
    },
    "production-pro": {
      "ios": {}
    }
  }
}
