{
  "expo": {
    "name": "serviapp-mobile",
    "slug": "serviapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whalesrecords.serviapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3366ff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.whalesrecords.serviapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SERVI utilise votre position pour afficher les prestataires proches de vous."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SERVI accède à vos photos pour définir votre photo de profil."
        }
      ],
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "SERVI ajoute vos réservations confirmées à votre agenda."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "SERVI vous permet d'ajouter un prestataire à vos contacts."
        }
      ]
    ],
    "scheme": "serviapp",
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5cbcde0f-9363-4f54-9a32-162a0895c634"
      }
    },
    "owner": "servi-fr"
  }
}
